{
  "version": 2,
  "builds": [
    {
      "src": "Backend/main.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": "Frontend/**"
      }
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "Backend/main.py"
    },
    {
      "src": "/api/(.*)",
      "dest": "Backend/main.py"
    },
    {
      "src": "/(.*)",
      "dest": "Backend/main.py"
    }
  ]
}