{
  "version": 2,
  "builds": [
    {
      "src": "Backend/main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "Backend/main.py"
    },
    {
      "src": "/assets/(.*)",
      "dest": "Frontend/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "Backend/main.py"
    }
  ],
  "functions": {
    "Backend/main.py": {
      "includeFiles": "Frontend/**"
    }
  }
}